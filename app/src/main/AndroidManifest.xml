<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Vibration permission for haptic feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <!-- Microphone permission for voice typing -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:label="Horizon Keyboard"
        android:supportsRtl="true"
        android:theme="@style/Theme.HorizonKeyboard">

        <!-- Input Method Service - the core keyboard service -->
        <service
            android:name=".MiMoInputMethodService"
            android:exported="true"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:directBootAware="false">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

        <!-- Settings Activity so users can enable the keyboard -->
        <activity
            android:name=".MiMoSettingsActivity"
            android:exported="true"
            android:label="Horizon Keyboard"
            android:theme="@style/Theme.HorizonKeyboard"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>
</manifest>
